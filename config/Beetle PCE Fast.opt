# Beetle PCE Fast — Core Options
# Paired with: config/Beetle PCE Fast/Beetle PCE Fast.cfg

# Disabled: loads entire CD into RAM (200–700 MB). Apple TV has 4 GB total;
# risks tvOS cache purge. Re-enable per-game for heavy seek titles (Rondo of Blood).
pce_fast_cdimagecache = "disabled"
pce_fast_nospritelimit = "enabled"
