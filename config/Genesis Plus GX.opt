# Genesis Plus GX — Core Options
# nuked ym2612 cycle-accurate fm synthesis 3 cpu cost vs mame
genesis_plus_gx_ym2612 = "nuked (ym2612)"
genesis_plus_gx_audio_filter = "low-pass"
genesis_plus_gx_lowpass_range = "55"
genesis_plus_gx_no_sprite_limit = "enabled"
# per-game bram isolation sega cd upstream splits two keys libretro/genesis-plus-gx
genesis_plus_gx_system_bram = "per game"
genesis_plus_gx_cart_bram = "per game"
