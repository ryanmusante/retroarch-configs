# PCSX-ReARMed — Core Options
# Paired with: config/PCSX-ReARMed/PCSX-ReARMed.cfg
# pcsx_rearmed_psxclock: lower to 50 per-game for demanding titles

pcsx_rearmed_drc = "disabled"
pcsx_rearmed_duping_enable = "enabled"
pcsx_rearmed_frameskip = "Off"
pcsx_rearmed_frameskip_threshold = "30"
pcsx_rearmed_gpu_thread_rendering = "Synchronous"
pcsx_rearmed_async_cd = "enabled"
pcsx_rearmed_psxclock = "57"
