# PS1 core options: DRC off, auto_threshold frameskip @ 33% buffer (interpreter safety on no-JIT A15), async GPU, psxclock 100, cd_readahead 333000 (full-disk precache, ~780 MB RAM)
# WARNING: cd_readahead=333000 is outside the Core Options menu enum. DO NOT open Quick Menu -> Options -> Manage Core Options -> Save -- menu-save silently replaces 333000 with the nearest dropdown value (typically 768) and breaks the precache. Edit this file directly only.
pcsx_rearmed_drc = "disabled"
pcsx_rearmed_frameskip_type = "auto_threshold"
pcsx_rearmed_frameskip_threshold = "33"
pcsx_rearmed_gpu_thread_rendering = "async"
pcsx_rearmed_psxclock = "100"
pcsx_rearmed_cd_readahead = "333000"
