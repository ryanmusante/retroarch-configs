# PS1 core options: DRC off, no frameskip, async GPU, psxclock 100, cd_readahead 333000 (full-disk precache)
pcsx_rearmed_drc = "disabled"
pcsx_rearmed_frameskip_type = "disabled"
pcsx_rearmed_gpu_thread_rendering = "async"
pcsx_rearmed_psxclock = "100"
pcsx_rearmed_neon_enhancement_enable = "disabled"
pcsx_rearmed_cd_readahead = "333000"
